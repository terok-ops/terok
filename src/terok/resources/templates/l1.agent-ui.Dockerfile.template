# syntax=docker/dockerfile:1
ARG BASE_IMAGE=terok-l0:latest
FROM ${BASE_IMAGE}

ARG TEROK_UI_DIST_TAG=latest

ENV HOST="0.0.0.0" \
    PORT="7860" \
    TEROK_UI_DIR="/opt/terok-web-ui" \
    TEROK_UI_DIST_TAG="${TEROK_UI_DIST_TAG}" \
    TEROK_UI_DIST_URL="https://github.com/terok-ai/terok-web-ui/releases/download/${TEROK_UI_DIST_TAG}/terok-web-ui-dist.tar.gz"

# === Root operations ===
USER root
ENV HOME=/root

RUN apt-get update && apt-get install -y --no-install-recommends \
      ssh ca-certificates python-is-python3 python3 git nodejs curl \
    && rm -rf /var/lib/apt/lists/*

RUN set -eux; \
    printf '%s\n' \
      'alias codex="GIT_AUTHOR_NAME=Codex GIT_AUTHOR_EMAIL=codex@openai.com GIT_COMMITTER_NAME="\${HUMAN_GIT_NAME:-Nobody}" GIT_COMMITTER_EMAIL="\${HUMAN_GIT_EMAIL:-nobody@localhost}" codex --dangerously-bypass-approvals-and-sandbox"' \
      'alias claude="GIT_AUTHOR_NAME=Claude GIT_AUTHOR_EMAIL=noreply@anthropic.com GIT_COMMITTER_NAME="\${HUMAN_GIT_NAME:-Nobody}" GIT_COMMITTER_EMAIL="\${HUMAN_GIT_EMAIL:-nobody@localhost}" claude --dangerously-skip-permissions"' \
      'alias copilot="GIT_AUTHOR_NAME=\"GitHub Copilot\" GIT_AUTHOR_EMAIL=copilot@github.com GIT_COMMITTER_NAME=\"\${HUMAN_GIT_NAME:-Nobody}\" GIT_COMMITTER_EMAIL=\"\${HUMAN_GIT_EMAIL:-nobody@localhost}\" copilot"' \
      > /etc/profile.d/terok-agent-aliases.sh; \
    if [ -f /etc/bash.bashrc ]; then \
      printf '\n# terok agent aliases\n. /etc/profile.d/terok-agent-aliases.sh\n' >> /etc/bash.bashrc; \
    else \
      printf '# terok agent aliases\n. /etc/profile.d/terok-agent-aliases.sh\n' > /etc/bash.bashrc; \
    fi

RUN set -eux; \
    mkdir -p "${TEROK_UI_DIR}"; \
    tarball_path="/tmp/terok-web-ui-dist.tar.gz"; \
    curl -fsSL "${TEROK_UI_DIST_URL}" -o "${tarball_path}"; \
    if [ ! -s "${tarball_path}" ]; then \
      echo "!! failed to download Terok Web UI distribution (file is missing or empty): ${tarball_path}"; \
      exit 1; \
    fi; \
    if ! tar -tzf "${tarball_path}" >/dev/null 2>&1; then \
      echo "!! downloaded Terok Web UI archive appears to be corrupted or not a valid tar.gz: ${tarball_path}"; \
      exit 1; \
    fi; \
    tar -xzf "${tarball_path}" -C "${TEROK_UI_DIR}"; \
    rm -f "${tarball_path}"; \
    if [ ! -f "${TEROK_UI_DIR}/dist/server.js" ]; then \
      echo "!! no UI entrypoint found (expected dist/server.js)."; \
      exit 1; \
    fi; \
    chown -R dev:dev "${TEROK_UI_DIR}"

COPY scripts/terok-ui-entry.sh /usr/local/bin/terok-ui-entry.sh
RUN chmod +x /usr/local/bin/terok-ui-entry.sh

EXPOSE 7860

# === User operations ===
ENV HOME=/home/dev
USER dev
CMD ["terok-ui-entry.sh"]