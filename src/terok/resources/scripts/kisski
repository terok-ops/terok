"""
KISSKI launcher for OpenCode.

Fetches models from KISSKI's OpenAI-compatible API and runs OpenCode
with full permissions. Model selection can be done inside OpenCode.
"""

import argparse
import json
import os
import subprocess
from collections.abc import Iterable
from pathlib import Path
from urllib import error, request

DEFAULT_BASE_URL = "https://chat-ai.academiccloud.de/v1"
PREFERRED_MODEL = "devstral-2-123b-instruct-2512"
FALLBACK_MODEL = "mistral-large-3-675b-instruct-2512"


def _config_dir() -> Path:
    return Path.home() / ".kisski"


def _config_path() -> Path:
    return _config_dir() / "config.json"


def _load_api_key() -> str | None:
    api_key = os.environ.get("KISSKI_API_KEY")
    if api_key:
        return api_key
    cfg_path = _config_path()
    if not cfg_path.is_file():
        return None
    try:
        data = json.loads(cfg_path.read_text())
    except (OSError, json.JSONDecodeError):
        return None
    val = data.get("api_key")
    return val if isinstance(val, str) and val.strip() else None


def _fetch_models(base_url: str, api_key: str) -> list[str] | None:
    """Fetch available models from the API. Returns None on failure."""
    url = base_url.rstrip("/") + "/models"
    req = request.Request(
        url,
        headers={
            "Authorization": f"Bearer {api_key}",
            "Accept": "application/json",
        },
    )
    try:
        with request.urlopen(req, timeout=30) as resp:
            payload = json.loads(resp.read().decode("utf-8"))
    except (error.HTTPError, error.URLError, json.JSONDecodeError):
        return None

    items: Iterable[object] = []
    if isinstance(payload, dict):
        if isinstance(payload.get("data"), list):
            items = payload["data"]
        elif isinstance(payload.get("models"), list):
            items = payload["models"]

    models: list[str] = []
    for item in items:
        if isinstance(item, dict):
            model_id = item.get("id")
            if isinstance(model_id, str) and model_id:
                models.append(model_id)

    return sorted(set(models)) if models else None


def _build_kisski_update(base_url: str, api_key: str, model: str, models: list[str] | None) -> dict:
    """Build the KISSKI-specific config fragment to merge into opencode.json.

    Returns a dict containing only the keys that KISSKI needs to set or
    update: ``$schema``, ``model``, ``provider.kisski``, and ``permission``.
    """
    model_map = {model: {"name": model}}
    if models:
        for mid in models:
            if isinstance(mid, str) and mid:
                model_map.setdefault(mid, {"name": mid})
    return {
        "$schema": "https://opencode.ai/config.json",
        "model": f"kisski/{model}",
        "provider": {
            "kisski": {
                "npm": "@ai-sdk/openai-compatible",
                "name": "KISSKI",
                "options": {
                    "baseURL": base_url,
                    "apiKey": api_key,
                },
                "models": model_map,
            }
        },
        "permission": {
            "*": "allow",
        },
    }


def _merge_kisski_config(existing: dict, update: dict) -> dict:
    """Merge a KISSKI update into an existing opencode.json config.

    Only the ``provider.kisski`` section is replaced wholesale; other
    provider entries and top-level keys (e.g. ``instructions``) are preserved.
    ``model`` is set only if currently unset or already kisski-prefixed.
    ``permission`` is set only if currently unset.
    """
    merged = dict(existing)

    existing_schema = merged.get("$schema")
    expected_schema = update["$schema"]
    if existing_schema and existing_schema != expected_schema:
        print(
            f"Warning: opencode.json has unexpected $schema value "
            f"{existing_schema!r}, expected {expected_schema!r}. Overwriting."
        )
    merged["$schema"] = expected_schema

    existing_providers = merged.get("provider")
    if not isinstance(existing_providers, dict):
        existing_providers = {}
    update_providers = update.get("provider", {})
    merged_providers = dict(existing_providers)
    merged_providers.update(update_providers)
    merged["provider"] = merged_providers

    current_model = merged.get("model")
    if not current_model or (
        isinstance(current_model, str) and current_model.startswith("kisski/")
    ):
        merged["model"] = update["model"]

    if "permission" not in merged:
        merged["permission"] = update["permission"]

    return merged


def _opencode_config_path() -> Path:
    """Return the KISSKI-specific OpenCode config path.

    Lives under ~/.kisski/opencode/ so it does not conflict with plain
    OpenCode's default config at ~/.config/opencode/opencode.json.
    The OPENCODE_CONFIG env var is used at launch time to point OpenCode here.
    """
    return _config_dir() / "opencode" / "opencode.json"


def _load_opencode_config() -> dict | None:
    """Load existing OpenCode config if present."""
    config_path = _opencode_config_path()
    if not config_path.is_file():
        return None
    try:
        return json.loads(config_path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None


def _get_configured_models(config: dict | None) -> set[str]:
    """Extract model IDs from an existing kisski provider config."""
    if not config:
        return set()
    try:
        models = config.get("provider", {}).get("kisski", {}).get("models", {})
        return set(models.keys()) if isinstance(models, dict) else set()
    except (AttributeError, TypeError):
        return set()


def _get_configured_options(config: dict | None) -> dict:
    """Extract provider options (baseURL, apiKey) from existing config."""
    if not config:
        return {}
    try:
        options = config.get("provider", {}).get("kisski", {}).get("options", {})
        return options if isinstance(options, dict) else {}
    except (AttributeError, TypeError):
        return {}


def _write_opencode_config(config: dict) -> Path:
    """Write config to OpenCode's standard location via atomic replace.

    Uses write-to-temp + ``os.replace`` so concurrent kisski instances
    never see a partially-written file.

    Note: no file locking is used by design.  All concurrent kisski
    instances write semantically equivalent data (same API, same model list),
    so content races are harmless.  The atomic replace is only needed to
    prevent readers from seeing a partially-written file.
    """
    import tempfile

    config_path = _opencode_config_path()
    config_path.parent.mkdir(parents=True, exist_ok=True)
    tmp_path = None
    try:
        with tempfile.NamedTemporaryFile(
            "w", encoding="utf-8", dir=config_path.parent, suffix=".tmp", delete=False
        ) as f:
            tmp_path = f.name
            f.write(json.dumps(config, indent=2) + "\n")
        os.replace(tmp_path, config_path)
    except BaseException:
        if tmp_path and os.path.exists(tmp_path):
            os.unlink(tmp_path)
        raise
    return config_path


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="kisski",
        description="Run OpenCode against KISSKI with full permissions.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  kisski                # launch with preferred model\n"
            "  kisski --list-models  # list available models\n"
            "  kisski -- --help      # pass flags to opencode\n"
        ),
    )
    parser.add_argument("--list-models", action="store_true", help="List available models and exit")
    parser.add_argument(
        "--base-url",
        default=None,
        help=f"Override API base URL (default: {DEFAULT_BASE_URL})",
    )

    args, opencode_args = parser.parse_known_args()

    api_key = _load_api_key()
    if not api_key:
        raise SystemExit(
            "Missing KISSKI_API_KEY. Set it in the environment or write "
            f'{{"api_key": "..."}} to {_config_path()}.'
        )

    base_url = args.base_url or os.environ.get("KISSKI_BASE_URL") or DEFAULT_BASE_URL
    base_url = base_url.rstrip("/")

    fetched_models = _fetch_models(base_url, api_key)

    if args.list_models:
        if fetched_models:
            for model in fetched_models:
                print(model)
        else:
            raise SystemExit("Failed to fetch models from KISSKI API")
        return 0

    existing_config = _load_opencode_config()
    configured_models = _get_configured_models(existing_config)

    model = PREFERRED_MODEL
    if fetched_models and PREFERRED_MODEL not in fetched_models:
        print(
            f"Warning: Preferred model '{PREFERRED_MODEL}' is no longer available.\n"
            f"Falling back to '{FALLBACK_MODEL}'.\n"
            "Check for new upstream versions of terok to update the default model."
        )
        model = FALLBACK_MODEL

    stored_options = _get_configured_options(existing_config)
    options_changed = (
        stored_options.get("baseURL") != base_url or stored_options.get("apiKey") != api_key
    )
    if fetched_models:
        fetched_set = set(fetched_models)
        needs_update = fetched_set != configured_models or options_changed
        if needs_update:
            new_models = fetched_set - configured_models
            if new_models:
                print(f"New models available: {', '.join(sorted(new_models))}")
            update = _build_kisski_update(base_url, api_key, model, fetched_models)
            merged = _merge_kisski_config(existing_config or {}, update)
            _write_opencode_config(merged)
    elif options_changed or not configured_models:
        fallback_models = sorted(configured_models) if configured_models else [model]
        update = _build_kisski_update(base_url, api_key, model, fallback_models)
        merged = _merge_kisski_config(existing_config or {}, update)
        _write_opencode_config(merged)

    cmd = ["opencode"] + opencode_args
    env = {**os.environ, "OPENCODE_CONFIG": str(_opencode_config_path())}
    try:
        return subprocess.call(cmd, env=env)
    except FileNotFoundError:
        raise SystemExit("opencode not found. Rebuild the L1 CLI image to install it.")


if __name__ == "__main__":
    raise SystemExit(main())
