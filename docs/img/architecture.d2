vars: {
  d2-config: {
    pad: 16
  }
}

# Transparent root so the SVG inherits the host page's
# light/dark background; theme-aware fills handle the rest.
style.fill: transparent

direction: right

operator: |md
  ### Operator
  CLI · TUI ·
  desktop popups
| {
  width: 200
  style: {
    fill: "#dcfce7"
    stroke: "#15803d"
    stroke-width: 2
    border-radius: 14
  }
}

container: |md
  ### Per-task container
  - Agent CLI · /workspace
  - Layered instructions
  - Standard dev tools
  - rootless Podman, no host privileges
| {
  width: 320
  style: {
    fill: "#dbeafe"
    stroke: "#1d4ed8"
    stroke-width: 2
    border-radius: 14
  }
}

boundary: |md
  ### Boundary services *(host-side)*
  - default-deny egress firewall
  - credential vault on host
  - per-task git gate
  - live clearance verdicts
| {
  width: 280
  style: {
    fill: "#ffedd5"
    stroke: "#c2410c"
    stroke-width: 2
    border-radius: 14
  }
}

world: |md
  ### Allowed external world
  - LLM endpoints
  - Git remote
  - Package registries
| {
  width: 230
  style: {
    fill: "#f1f5f9"
    stroke: "#475569"
    stroke-width: 2
    border-radius: 14
  }
}

operator -> container: "creates"
container -> boundary: "every outbound\nrequest"
boundary -> world: "if allowed"
